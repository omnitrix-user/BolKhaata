# ─────────────────────────────────────────────────────────────
# BolKhaata backend configuration. Copy this file to `.env` and fill in.
# Every key is OPTIONAL — the app runs without any of them (voice falls back
# to an on-device heuristic parser, and WhatsApp uses free wa.me deep links).
# Add keys to unlock the better experience.
# ─────────────────────────────────────────────────────────────

# Intent parsing (Hindi/Kannada/Hinglish -> structured entry).
# Resolution order: local Ollama  ->  OpenRouter (if key)  ->  built-in heuristic.
#
# (A) LOCAL LLM via Ollama — recommended: free, private, offline, no API key.
#     Install https://ollama.com  then:  ollama pull qwen2.5:1.5b
#     The defaults below work as soon as Ollama is running. Set USE_OLLAMA=0 to
#     skip it. OLLAMA_MODEL can be any model you've pulled (e.g. llama3.2:3b).
USE_OLLAMA=1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
#
# (B) HOSTED LLM via OpenRouter — optional fallback. Get a key at
#     https://openrouter.ai/keys  (NEVER paste a real key in this example file).
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-chat

# Speech-to-text (turns the recorded voice into text).
# Without this, the mic still records but you'll use the "type instead" box.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# WhatsApp auto-send (OPTIONAL). The app works without this using free wa.me
# deep links that open the shopkeeper's own WhatsApp. Fill these only if you
# want the server to send reminders automatically via Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# CORS (OPTIONAL). Comma-separated list of allowed origins. Leave blank to
# allow localhost + LAN IPs automatically (so a phone on the same wifi works).
CORS_ORIGINS=
